# ============================================================
# Writers Block - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ----------------------------------------------------------
# Site Configuration
# ----------------------------------------------------------
# Used for absolute invite links, SSO callback URLs, QStash worker URLs, sitemap, robots, and emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional legacy alias used only as a fallback for invite links when NEXT_PUBLIC_SITE_URL is missing.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: shown as mailto in marketing footer "Contact" when set (otherwise links to Siru AI Labs site)
# NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com

# ----------------------------------------------------------
# Supabase Configuration
# Get these from your Supabase project settings
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase SAML SSO providers are configured in Supabase Dashboard, not in app env.
# Add provider client IDs/secrets in Supabase Dashboard only; do not expose provider secrets in NEXT_PUBLIC_* vars.
# Add this app callback to Supabase Auth redirect allowlist:
#   https://your-domain.com/auth/callback

# Supabase Service Role Key (server-side only — never expose to client)
# Required for: project quota RPC, AI budget rollups, webhook handler, admin dashboard, cron jobs
# Get from: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database connection pooler (for serverless functions)
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_DATABASE_URL=your_supabase_connection_pooler_url

# SCIM bearer tokens are generated in-app through:
#   PATCH /api/org/security-policy with rotateScimToken=true
# Do not store SCIM bearer tokens in env; only hashed token state is stored in the database.

# ----------------------------------------------------------
# AI/ML API Keys
# ----------------------------------------------------------

# Direct AI provider keys used by the smart router.
OPENAI_API_KEY=sk-your_openai_key
GEMINI_API_KEY=your_gemini_api_key
# Optional Gemini fallback name also accepted by the AI router.
# GOOGLE_AI_API_KEY=your_google_ai_api_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# Optional model overrides. Format for *_MODELS: provider:model,provider:model
# AI_SIMPLE_MODELS=gemini:gemini-2.5-flash-lite,openai:gpt-4o-mini
# AI_STANDARD_MODELS=gemini:gemini-2.5-flash,openai:gpt-5.4-mini,anthropic:claude-haiku-4-5-20251001
# AI_COMPLEX_MODELS=openai:gpt-5.4,anthropic:claude-sonnet-4-6
# Optional per-provider defaults used when *_MODELS is not set.
# AI_GEMINI_SIMPLE_MODEL=gemini-2.5-flash-lite
# AI_OPENAI_SIMPLE_MODEL=gpt-4o-mini
# AI_ANTHROPIC_SIMPLE_MODEL=claude-haiku-4-5-20251001
# AI_GEMINI_STANDARD_MODEL=gemini-2.5-flash
# AI_OPENAI_STANDARD_MODEL=gpt-5.4-mini
# AI_ANTHROPIC_STANDARD_MODEL=claude-haiku-4-5-20251001
# AI_OPENAI_COMPLEX_MODEL=gpt-5.4
# AI_ANTHROPIC_COMPLEX_MODEL=claude-sonnet-4-6
# AI_GEMINI_COMPLEX_MODEL=gemini-3.1-pro-preview
# AI_ENABLE_GEMINI_3_1_PRO=false

# Cost controls.
AI_EXCHANGE_RATE_INR_PER_USD=95
# Local development may fail open if Supabase service role is absent. Production fails closed unless explicitly set.
# AI_BUDGET_FAIL_OPEN=true
# AI_PROMPT_CACHE_TTL_HOURS=24

# Story memory retrieval/indexing. Uses OpenAI embeddings even when generation routes to Gemini/Anthropic.
# Requires the pgvector schema in supabase/database.sql.
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536
STORY_MEMORY_TOP_K=8
STORY_MEMORY_MAX_CONTEXT_TOKENS=3000

# Deterministic AI provider mode for Playwright/E2E. Never enable in production.
# AI_PROVIDER_MOCK=true

# Maximum output tokens for screenplay generation.
MAX_TOKENS=8000

# ----------------------------------------------------------
# Redis/Rate Limiting (Upstash)
# Required for distributed rate limiting
# Get from: https://console.upstash.com
# ----------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Production / next start: AI routes return 503 if Redis env vars are missing.
# Set only for emergencies or self-hosted setups without Upstash (not recommended):
# ALLOW_AI_WITHOUT_REDIS=1

# ----------------------------------------------------------
# Payment Processing (Razorpay)
# Get from: https://dashboard.razorpay.com
# ----------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Webhook secret for server-side payment verification.
# Set this in: Razorpay Dashboard → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Required webhook events: payment.captured and subscription.*.

# Razorpay Subscription plan IDs. Required for paid plan checkout.
# One-time clean PDF export and AI credit top-up still use Razorpay Orders.
RAZORPAY_PLAN_PRO_MONTHLY=plan_your_pro_monthly
RAZORPAY_PLAN_PRO_ANNUAL=plan_your_pro_annual
RAZORPAY_PLAN_PREMIUM_MONTHLY=plan_your_premium_monthly
RAZORPAY_PLAN_PREMIUM_ANNUAL=plan_your_premium_annual

# ----------------------------------------------------------
# Pricing (in Indian Paise — 1 INR = 100 paise)
# Override these to change prices without a code deploy
# ----------------------------------------------------------
PRO_MONTHLY_PRICE_PAISE=119900
PRO_ANNUAL_PRICE_PAISE=1151000
PREMIUM_MONTHLY_PRICE_PAISE=399900
PREMIUM_ANNUAL_PRICE_PAISE=3839000
PDF_CLEAN_EXPORT_PRICE_PAISE=9900
AI_CREDIT_TOPUP_PRICE_PAISE=9900

# ----------------------------------------------------------
# Email Notifications (Resend)
# Get from: https://resend.com
# ----------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@writersblock.app

# OTP payload encryption. Set explicit production secrets instead of relying on provider keys.
# Generate with: openssl rand -hex 32
AUTH_OTP_SECRET=your_random_auth_otp_secret
MASTER_ADMIN_OTP_SECRET=your_random_master_admin_otp_secret

# ----------------------------------------------------------
# Admin access (database — not env email lists)
# Guide: docs/admin-operators.md
# After running supabase/database.sql, grant operators with:
#   INSERT INTO master_admin.users (user_id, note)
#   VALUES ('<uuid from auth.users>', 'founder');
# Same auth users still have rows in public.profiles; privileges are only in master_admin.users.
# Expose `user_auth` and `master_admin` in Supabase Dashboard -> API settings.
# Requires SUPABASE_SERVICE_ROLE_KEY for checks (middleware + APIs). ADMIN_EMAILS is unused.
# ----------------------------------------------------------

# Master Admin — comma-separated Host header values (include port for non-443 dev)
# Example production: admin.writersblock.siru.ai
# Example local: localhost:3000
# If empty, /master-admin and /api/master-admin return 404 on all hosts (fail closed).
ADMIN_HOSTS=localhost:3000

# HMAC secret for Master Admin signup fraud detection. Raw IPs/user agents are never persisted.
# Generate with: openssl rand -hex 32
FRAUD_SIGNAL_HASH_SECRET=your_random_fraud_signal_hash_secret

# Master Admin: production requires MFA (JWT aal2) by default.
# Local/staging can opt in with 1; production break-glass can explicitly set 0/false/no for a documented window.
# See docs/admin-operators.md
# REQUIRE_AAL2_FOR_MASTER_ADMIN=1

# Organization IAM: require MFA (JWT aal2) for privileged org actions such as member management and audit reads.
# See docs/iam-enterprise.md
# REQUIRE_AAL2_FOR_IAM_ADMIN=1

# ----------------------------------------------------------
# Cron Jobs (Vercel)
# Set this in Vercel project settings → Environment Variables
# Used to protect /api/cron/* endpoints, including /api/cron/check-subscriptions and /api/cron/cleanup-enterprise.
# Production (VERCEL_ENV or NODE_ENV=production): REQUIRED — cron returns 503 if unset; calls must send Authorization: Bearer <CRON_SECRET>.
# Local dev: optional; if set, same Bearer header is required.
# ----------------------------------------------------------
CRON_SECRET=your_random_cron_secret_here

# ----------------------------------------------------------
# Optional: Sentry (error monitoring)
# Client + server init when DSN is set; events scrub auth cookies/headers (see src/modules/sentry-scrub.ts).
# Source map upload in CI: set SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT (build uses dryRun when token absent).
# ----------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_DSN=  # optional server-only override
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ----------------------------------------------------------
# Queue System (Upstash QStash)
# Required in production for async legacy Razorpay post-payment side effects, AI batch jobs,
# and story memory indexing:
# subscription event history, confirmation email, business analytics logging,
# non-real-time AI work, and /api/jobs/story-memory processing.
# ----------------------------------------------------------
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_qstash_signing_key
QSTASH_NEXT_SIGNING_KEY=your_qstash_next_signing_key
# Optional bearer/header fallback for direct AI batch worker calls when not using QStash.
# AI_BATCH_JOB_SECRET=your_random_ai_batch_secret
# Optional bearer/header fallback for direct story memory worker calls when not using QStash.
# The worker route is /api/jobs/story-memory.
# STORY_MEMORY_JOB_SECRET=your_random_story_memory_secret

# ----------------------------------------------------------
# WAF (Web Application Firewall) — Middleware Layer
# See docs/security-architecture.md for details
# ----------------------------------------------------------
# Master kill switch (default: true)
WAF_ENABLED=true

# Dry-run mode: log detections without blocking.
# Default when unset: true outside production, false in production.
# For first rollout, set WAF_DRY_RUN=true temporarily and monitor logs before enforcing.
# WAF_DRY_RUN=true

# Comma-separated IPs that bypass WAF checks (e.g., office IP, CI runners)
# WAF_ALLOWED_IPS=203.0.113.10,198.51.100.20

# Comma-separated ISO country codes to geo-block (uses Cloudflare CF-IPCountry)
# WAF_BLOCKED_COUNTRIES=

# ----------------------------------------------------------
# Internal API Security
# Optional shared fallback for app-owned background job routes.
# Send as Authorization: Bearer <INTERNAL_API_SECRET> or x-internal-api-secret.
# Cron uses CRON_SECRET; Razorpay uses Razorpay HMAC signatures.
# Generate with: openssl rand -hex 32
# ----------------------------------------------------------
# INTERNAL_API_SECRET=your_random_hex_secret_here

# ----------------------------------------------------------
# E2E test helpers (local/CI only)
# Enables /api/test/e2e/* routes for deterministic auth, payment, and provider setup.
# These routes return 404 in production regardless of env values.
# ----------------------------------------------------------
# ENABLE_E2E_TEST_ROUTES=true
# E2E_TEST_SECRET=your_random_e2e_test_secret
# E2E_PORT=3100
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3100

# ----------------------------------------------------------
# Infrastructure as Code (Terraform + Cloudflare)
# These are typically set in Terraform Cloud, not here.
# Listed for reference only.
# ----------------------------------------------------------
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
# CLOUDFLARE_ZONE_ID=your_zone_id
# TF_API_TOKEN=your_terraform_cloud_api_token
